    "harness": "vitest run",
    "assets": "node tools/build-kit.mjs"
  },
  "dependencies": {
    "postprocessing": "^6.39.1",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@gltf-transform/core": "^4.3.0",
    "@gltf-transform/extensions": "^4.3.0",
    "@gltf-transform/functions": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/three": "^0.184.0",
    "meshoptimizer": "^1.1.1",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.7"
  }
}
