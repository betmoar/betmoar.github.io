{
  "name": "voxel-city2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Hybrid rebuild of Voxel City — deterministic procedural world rendered with authored assets. M0 scaffold.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
